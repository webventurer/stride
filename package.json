{
  "name": "flowfu",
  "version": "0.1.0",
  "description": "All the speed. None of the mess. Claude Code skills for atomic commits and Linear workflow.",
  "scripts": {
    "dev": "vitepress dev docs",
    "build:docs": "vitepress build docs",
