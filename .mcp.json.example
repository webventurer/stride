{
  "mcpServers": {

    "_comment_oauth": "Option 1: OAuth (single workspace) — browser login, no keys needed",
    "linear": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.linear.app/mcp"]
    },

    "_comment_api_key": "Option 2: API key (multiple orgs) — one entry per org",
    "linear-org1": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp",
        "--header",
        "Authorization:Bearer ${LINEAR_ORG1_API_KEY}"
      ],
      "env": {
        "LINEAR_ORG1_API_KEY": "${LINEAR_ORG1_API_KEY}"
      }
    },
    "linear-org2": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp",
        "--header",
        "Authorization:Bearer ${LINEAR_ORG2_API_KEY}"
      ],
      "env": {
        "LINEAR_ORG2_API_KEY": "${LINEAR_ORG2_API_KEY}"
      }
    }
  }
}
